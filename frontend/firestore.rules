// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {uid} (Firebase Auth UID)
// Fields:
//   - email: string (required) - User's email address
//   - display_name: string (required, 1-100 chars) - User's display name
//   - role: string (required, ['user', 'admin']) - User's role
//   - created_at: timestamp (required) - Registration date
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "miracle.adeoye@incedoinc.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      let requiredFields = ['email', 'display_name', 'role', 'created_at'];
      let allowedFields = ['email', 'display_name', 'role', 'created_at', 'last_login_at', 'industry', 'client_company', 'consultant_name'];
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.email is string &&
             data.display_name is string && data.display_name.size() >= 1 && data.display_name.size() <= 100 &&
             data.role in ['user', 'admin'] &&
             data.created_at is timestamp &&
             (!('last_login_at' in data) || data.last_login_at is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read their own profile. Admins can read all profiles.
      allow read: if isOwner(userId) || isAdmin();

      // Creation:
      // 1. User can create their own profile if role is 'user'.
      // 2. Admin can create any profile.
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (
        (isOwner(userId) && request.resource.data.role == 'user') ||
        isAdmin()
      );

      // Update:
      // 1. User can update their own display_name and last_login_at, but NOT role or email.
      // 2. Admin can update anything.
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (
        (isOwner(userId) && 
         request.resource.data.role == resource.data.role && 
         request.resource.data.email == resource.data.email) ||
        isAdmin()
      );

      allow delete: if isAdmin();
    }
  }
}
